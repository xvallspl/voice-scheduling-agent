# Server Configuration
PORT=8000
ENVIRONMENT=development

# Security
# The token the Voice Provider must send in the Authorization header
WEBHOOK_SECRET=your_super_secret_bearer_token_here

# Google Calendar Integration
# The ID of the specific calendar to insert events into (usually an email address)
GOOGLE_CALENDAR_ID=your_calendar_id@group.calendar.google.com

# Google Service Account Credentials
# Path to the JSON credentials file downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=credentials.json

# Application Settings
TIMEZONE=America/New_York
DEFAULT_EVENT_DURATION_MINUTES=60
DEFAULT_EVENT_TITLE=Meeting

# Logging
LOG_LEVEL=INFO
